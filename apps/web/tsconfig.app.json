{
  "extends": "./tsconfig.json",
  "include": ["src/**/*", "mocks", "stories", "app/layout.tsx", "app/page.tsx", "app/routeTree.gen.ts"],
  "compilerOptions": {
    "composite": true,
    "strict": true,
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "types": ["node"],
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "baseUrl": ".",
    "rootDirs": ["."],
    "paths": {
      "~/*": ["./src/*"],
      "~/mocks/*": ["./mocks/*"],
      "~/stories/*": ["./stories/*"]
    },
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "noEmit": false
  }
}
